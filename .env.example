# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Redis (for high-throughput queue)
REDIS_URL=redis://localhost:6379/0

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent_eval

# LLM (OpenAI-compatible API for evaluators)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1  # or Azure/other compatible endpoint

# Evaluation Settings
LATENCY_THRESHOLD_MS=1000
MAX_CONVERSATION_TURNS=20
